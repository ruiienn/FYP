<!DOCTYPE HTML>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>My Profile Details</title>
<link rel="icon" type="image/png" href="/img/nfc.png">
<link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
<script src="/bootstrap/css/bootstrap.js"></script>
<style>
.profile {
	background-color: #ececeb;
	border-radius: 30px;
	width: 80%;
	margin: 5% 10% 0%;
	padding: 15px;
	border: 2px solid #06B48B;
	display: flex;
	align-items: flex-start;
	justify-content: center;
	flex-wrap: wrap;
	height: auto;
}

.pfp-img {
	background-color: white;
	border-radius: 50%;
	width: 120px;
	height: 120px;
	position: static;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	margin-top: 30px;
}

.btn-next {
	background-color: #FFFFFF;
	display: flex;
	align-items: center;
	padding: 10px 50px;
	border-radius: 20px;
	text-decoration: none;
	color: black;
	margin-top: 20px;
}
.btn-login {
	font-size: 20px;
	color: white;
	text-decoration: none;
	background-color: #5184bf;
	width: 180px;
	height: 50px;
	border-radius: 30px;
	display: block;
	padding: 10px;
	margin: 50px 0 30px 130px;
}
</style>
</head>
<body>
	<div th:replace="fragments/style"></div>
	<div class="container">
		<div class="profile">
			<b><i> My Profile Details </i></b> <span class="pfp-img"></span>
			<div>
				<a href="/profile" target="_self" class="btn-login"
					style="margin-top: 100px; text-align: center"> Next </a>
			</div>
		</div>
	</div>
</body>
</html>